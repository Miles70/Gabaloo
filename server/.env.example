PORT=5000
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/kemalreis?retryWrites=true&w=majority
CLIENT_ORIGINS=http://localhost:5173
NODE_ENV=development

# Amazon Reviews 2023 demo catalog import
AMAZON_CATALOG_TARGET=2000
AMAZON_CATALOG_USER_AGENT=Kemalreis/0.1 (https://github.com/Miles70/kemalreis)

# Reusable catalog translation layer
# Supported providers: mymemory, libretranslate, deepl
TRANSLATION_PROVIDER=mymemory
TRANSLATION_TIMEOUT_MS=15000

# Optional for MyMemory; increases identifiable usage quota when supplied
TRANSLATION_EMAIL=

# Optional/custom endpoint. Leave empty to use the provider default.
TRANSLATION_API_URL=

# Required only for providers that need a key, such as DeepL or some LibreTranslate hosts.
TRANSLATION_API_KEY=
